#include <iostream>
#include <vector>
#include <string>
#include <map>
#include <ctime>
#include <iomanip>

using namespace std;

class Product {
public:
    int id;
    string name;
    double costPrice;
    double sellingPrice;
    int stock;

    Product(int id, string name, double costPrice, double sellingPrice, int stock) 
        : id(id), name(name), costPrice(costPrice), sellingPrice(sellingPrice), stock(stock) {}
};

class Inventory {
private:
    vector<Product> products;

public:
    void addProduct(int id, string name, double costPrice, double sellingPrice, int stock) {
        products.push_back(Product(id, name, costPrice, sellingPrice, stock));
    }

    void updateProduct(int id, string name, double costPrice, double sellingPrice, int stock) {
        for (auto &product : products) {
            if (product.id == id) {
                product.name = name;
                product.costPrice = costPrice;
                product.sellingPrice = sellingPrice;
                product.stock = stock;
                return;
            }
        }
        cout << "Product not found!" << endl;
    }

    void deleteProduct(int id) {
        for (size_t i = 0; i < products.size(); ++i) {
            if (products[i].id == id) {
                products.erase(products.begin() + i);
                return;
            }
        }
        cout << "Product not found!" << endl;
    }

    void showProducts() {
        for (const auto &product : products) {
            cout << "ID: " << product.id 
                 << ", Name: " << product.name 
                 << ", Cost Price: " << product.costPrice 
                 << ", Selling Price: " << product.sellingPrice 
                 << ", Stock: " << product.stock << endl;
        }
    }

    Product* getProductById(int id) {
        for (auto &product : products) {
            if (product.id == id) {
                return &product;
            }
        }
        return nullptr;
    }

    void restockNotification(int threshold) {
        for (const auto &product : products) {
            if (product.stock < threshold) {
                cout << "Low stock alert for Product ID: " << product.id 
                     << ", Name: " << product.name << endl;
            }
        }
    }
};

class SalesReport {
private:
    map<string, double> salesData;
    double totalProfit = 0.0;
    double totalLoss = 0.0;

public:
    void recordSale(const Product &product, int quantity) {
        time_t now = time(0);
        char* dt = ctime(&now);
        string date(dt);
        double totalSale = product.sellingPrice * quantity;
        double profitOrLoss = (product.sellingPrice - product.costPrice) * quantity;
        salesData[date] += totalSale;
        totalProfit += max(profitOrLoss, 0.0);
        totalLoss += max(-profitOrLoss, 0.0);
    }

    void generateReport() {
        cout << "Sales Report: " << endl;
        for (const auto &entry : salesData) {
            cout << "Date: " << entry.first << " Total Sales: " << entry.second << endl;
        }
    }

    void generateNetProfitLossReport() {
        double netProfitLoss = totalProfit - totalLoss;
        cout << "Net Profit/Loss: " << (netProfitLoss >= 0 ? "Profit: " : "Loss: ") 
             << abs(netProfitLoss) << endl;
    }
};

void barcodeScanner(Inventory &inventory, SalesReport &salesReport) {
    int barcode, quantity;
    cout << "Enter Product Barcode: ";
    cin >> barcode;
    Product *product = inventory.getProductById(barcode);
    if (product) {
        cout << "Enter Quantity: ";
        cin >> quantity;
        if (quantity <= product->stock) {
            product->stock -= quantity;
            salesReport.recordSale(*product, quantity);
            cout << "Sale recorded for " << product->name << ", Quantity: " << quantity << endl;
        } else {
            cout << "Insufficient stock for " << product->name << endl;
        }
    } else {
        cout << "Product not found!" << endl;
    }
}

int main() {
    Inventory inventory;
    SalesReport salesReport;
    int choice, id, stock;
    string name;
    double costPrice, sellingPrice;
    
    while (true) {
        cout << "\nInventory Management System\n";
