        cout << "3. Delete Product\n";
        cout << "4. Show Products\n";
        cout << "5. Restock Notification\n";
        cout << "6. Simulate Barcode Scanner\n";
        cout << "7. Generate Sales Report\n";
        cout << "8. Generate Net Profit/Loss Report\n";
        cout << "9. Exit\n";
        cout << "Enter your choice: ";
        cin >> choice;

        switch (choice) {
            case 1:
                cout << "Enter Product ID: ";
                cin >> id;
                cout << "Enter Product Name: ";
                cin.ignore(); // Ignore leftover newline character
                getline(cin, name);
                cout << "Enter Cost Price: ";
                cin >> costPrice;
                cout << "Enter Selling Price: ";
                cin >> sellingPrice;
                cout << "Enter Product Stock: ";
                cin >> stock;
                inventory.addProduct(id, name, costPrice, sellingPrice, stock);
                break;
            case 2:
                cout << "Enter Product ID: ";
                cin >> id;
                cout << "Enter New Product Name: ";
                cin.ignore(); // Ignore leftover newline character
                getline(cin, name);
                cout << "Enter New Cost Price: ";
                cin >> costPrice;
                cout << "Enter New Selling Price: ";
                cin >> sellingPrice;
                cout << "Enter New Product Stock: ";
                cin >> stock;
                inventory.updateProduct(id, name, costPrice, sellingPrice, stock);
                break;
            case 3:
                cout << "Enter Product ID to delete: ";
                cin >> id;
                inventory.deleteProduct(id);
                break;
            case 4:
                inventory.showProducts();
                break;
            case 5:
                cout << "Enter stock threshold for notifications: ";
                cin >> stock;
                inventory.restockNotification(stock);
                break;
            case 6:
                barcodeScanner(inventory, salesReport);
                break;
            case 7:
                salesReport.generateReport();
                break;
            case 8:
                salesReport.generateNetProfitLossReport();
                break;
            case 9:
                cout << "Exiting..." << endl;
                return 0;
            default:
                cout << "Invalid choice!" << endl;
        }
    }
    return 0;
}

